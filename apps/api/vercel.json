{
  "version": 2,
  "builds": [
    {
      "src": "src/serverless.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/serverless.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/channels/cron-sync",
      "schedule": "0 */4 * * *"
    }
  ]
}
